generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Rsvp {
  id                 Int      @id @default(autoincrement())
  firstName          String
  lastName           String
  email              String
  whatsapp           String
  attending          Boolean
  companionCount     Int      @default(0)
  companions         String   @default("[]")
  primaryFood        String?
  companionFood      String   @default("[]")
  allergies          String?
  needsBus           Boolean?
  message            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  guests             Guest[]
}

model SeatingTable {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  capacity  Int      @default(10)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  guests    Guest[]
}

model Guest {
  id          Int           @id @default(autoincrement())
  rsvpId      Int
  tableId     Int?
  firstName   String
  lastName    String?
  fullName    String
  role        String
  attending   Boolean      @default(true)
  food        String?
  allergies   String?
  needsBus    Boolean?
  email       String
  whatsapp    String
  tags        String        @default("[]")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  rsvp        Rsvp          @relation(fields: [rsvpId], references: [id], onDelete: Cascade)
  table       SeatingTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)

  @@index([rsvpId])
  @@index([tableId])
}
