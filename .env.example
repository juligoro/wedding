DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&connect_timeout=60&connection_limit=1&pool_timeout=60"
ADMIN_PASSWORD="CHANGE_ME"
ADMIN_SESSION_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"

# Confirmation email (Resend). Leave RESEND_API_KEY empty to disable sending.
RESEND_API_KEY=""
# Must use a domain verified in Resend, e.g. "Juli & Tomi <hola@juli-tomi.wedding>"
EMAIL_FROM=""
# Optional: where guest replies go (defaults to none)
EMAIL_REPLY_TO=""
# Optional: exact venue address included in the confirmation email
EVENT_ADDRESS=""

# Guests can edit their RSVP via their invite link until this moment (ISO with offset).
# Leave empty to allow editing indefinitely.
RSVP_EDIT_DEADLINE="2026-10-31T23:59:59-03:00"
# Optional: Waze deep link to the venue shown in the FAQ on invite pages
EVENT_WAZE_URL=""
